# Copy this file to .env for the Docker quickstart, to .env.local for local overrides, or export the variables in your environment.
# Do not commit real secrets, credentials, hostnames, or production paths.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> april/web-login ###
APRIL_APP_USERNAME=april
APRIL_APP_PASSWORD_HASH=
###< april/web-login ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> amagno ###
AMAGNO_BASE_URI=
AMAGNO_API_TOKEN=
AMAGNO_API_USERNAME=
AMAGNO_API_PASSWORD=
AMAGNO_API_AUTH_TYPE=
AMAGNO_CREDENTIAL_ID=1
AMAGNO_CONNECTIONS_FILE=config/amagno_connections.local.json
AMAGNO_MATCHING_FILE=var/april/local/matching.json
AMAGNO_TEMPLATE_DIR=var/april/local/templates
AMAGNO_CHECKPOINT_DIR=var/checkpoints
INTELLIGENCE_EVENT_SECRET=
###< amagno ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
###< doctrine/doctrine-bundle ###
