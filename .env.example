# Copy this file to .env for the Docker quickstart, to .env.local for local overrides, or export the variables in your environment.
# Do not commit real secrets, credentials, hostnames, or production paths.

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change-me
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> april/web-login ###
APRIL_APP_USERNAME=april
APRIL_APP_PASSWORD_HASH=
###< april/web-login ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> april/event-api ###
INTELLIGENCE_EVENT_SECRET=
# Local development only. Keep false for public/production deployments.
INTELLIGENCE_EVENT_ALLOW_UNSIGNED_DEV=false
###< april/event-api ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
###< doctrine/doctrine-bundle ###
