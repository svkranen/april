{% extends 'layout/base.html.twig' %}

{% block title %}{{ view.key }} · Prozessgrafik · APRIL{% endblock %}

{% block head %}
    <style>
        .mermaid-source {
            background: #0a2342; color: #eef9fa; border-radius: 0.8rem;
            padding: 1rem 1.1rem; overflow-x: auto; font-size: 0.85rem; line-height: 1.5;
            font-family: Consolas, "Liberation Mono", monospace; margin: 0.6rem 0 0;
        }
        details.mermaid-box { margin-top: 0.6rem; }
        details.mermaid-box > summary {
            cursor: pointer; font-weight: 600; color: var(--accent);
            padding: 0.2rem 0; user-select: none;
        }
        .legend { display: flex; gap: 0.45rem; flex-wrap: wrap; align-items: center; margin: 0.4rem 0 0.2rem; }
        .legend-title { font-weight: 700; color: var(--muted); font-size: 0.85rem; margin-right: 0.2rem; }
        .shape-legend { display: flex; gap: 1rem; flex-wrap: wrap; margin: 0.5rem 0 0.2rem; color: var(--muted); font-size: 0.88rem; }
        .shape-legend .glyph { font-weight: 800; color: var(--accent-deep); margin-right: 0.25rem; }
        .gs-critical { background: #fce4ec; color: #880e4f; border: 1px solid #880e4f; }
        .gs-deviation { background: #ffebee; color: #c62828; border: 1px solid #c62828; }
        .gs-warning { background: #fff8e1; color: #8a6d00; border: 1px solid #f9a825; }
        .gs-technical { background: #ede7f6; color: #4527a0; border: 1px solid #4527a0; }
        .gs-ok { background: #e8f5e9; color: #2e7d32; border: 1px solid #2e7d32; }
        .gs-not_calculated { background: #eeeeee; color: #555; border: 1px solid #757575; }
        .gs-structure { background: #f5f5f5; color: #455a64; border: 1px solid #90a4ae; }
    </style>
{% endblock %}

{% block body %}
    {# 1. Kopfbereich #}
    <div class="card">
        <p class="crumbs">
            <a href="{{ path('app_templates_show', { key: view.key }) }}">← Zurück zur Template-Detailseite</a>
            &nbsp;·&nbsp;
            <a href="{{ path('app_templates_index') }}">Template-Liste</a>
        </p>
        <h1>Prozessgrafik – {{ view.key }}</h1>
        <p class="meta-line">Key: <code>{{ view.key }}</code></p>
        <p class="meta-line">Version: <strong>{{ view.version }}</strong></p>

        <p class="muted">Zeigt den Soll-Prozess des Templates: Schritte, Verzweigungen (Entscheidungen)
        und Parallelgruppen. Mit aktivierten Findings wird jeder Schritt zusätzlich nach seinem
        Prüfstatus eingefärbt.</p>

        {# Geschwister-Navigation, konsistent zur Template-Detailseite #}
        <div class="header-actions">
            <a class="pill-link" href="{{ path('app_templates_documents', { key: view.key }) }}">Dokumente</a>
            <a class="pill-link" href="{{ path('app_templates_access', { key: view.key }) }}">Access &amp; Visibility</a>
            <a class="pill-link" href="{{ path('app_templates_docs', { key: view.key }) }}">Dokumentation</a>
        </div>

        {# Findings an/aus – immer beide Richtungen anbieten #}
        <div class="header-actions">
            {% if view.withFindings %}
                <a class="pill-link is-active" href="{{ path('app_templates_graph', { key: view.key, withFindings: 1 }) }}">Mit Findings</a>
                <a class="pill-link" href="{{ path('app_templates_graph', { key: view.key }) }}">Ohne Findings</a>
            {% else %}
                <a class="pill-link" href="{{ path('app_templates_graph', { key: view.key, withFindings: 1 }) }}">Mit Findings</a>
                <a class="pill-link is-active" href="{{ path('app_templates_graph', { key: view.key }) }}">Ohne Findings</a>
            {% endif %}
        </div>

        {% if view.withFindings %}
            {% if view.limitReached %}
                <p class="muted">Findings on-demand berechnet (nicht persistiert) – aus Performance-Gründen
                nur für die ersten {{ view.findingsLimit }} von {{ view.totalDocuments }} Dokumenten.</p>
            {% else %}
                <p class="muted">Findings on-demand über {{ view.processedDocuments }} Dokument(e) berechnet (nicht persistiert).</p>
            {% endif %}
        {% else %}
            <p class="muted">Findings werden nicht automatisch berechnet, um die Ansicht performant zu halten.
            Alle Schritte sind daher grau (<em>nicht berechnet</em>). Über „Mit Findings" wird der Status je Schritt ermittelt.</p>
        {% endif %}
    </div>

    {# 2. Mermaid-Quelltext (MVP: Codeblock, kein Browser-Rendering) #}
    <div class="card">
        <h2>Mermaid-Grafik</h2>
        <p class="muted">Dies ist der Mermaid-Quelltext des Prozesses. Er kann unverändert in einen
        Mermaid-Renderer (z. B. mermaid.live oder eine Markdown-Vorschau) eingefügt werden.
        Ein direktes Rendering im Browser ist bewusst ein späterer Schritt.</p>

        <div class="shape-legend">
            <span><span class="glyph">▭</span>Schritt (Farbe = Status)</span>
            <span><span class="glyph">◇</span>Entscheidung / Verzweigung</span>
            <span><span class="glyph">⬡</span>Parallelgruppe (Start / Zusammenführung)</span>
            <span><span class="glyph">◯</span>Start / Ende</span>
        </div>

        <details class="mermaid-box" open>
            <summary>Mermaid-Quelltext anzeigen/ausblenden</summary>
            <pre class="mermaid-source">{{ view.mermaidCode }}</pre>
        </details>
    </div>

    {# 3. Legende, prozessweite Findings und Schritt-Tabelle (barrierearmer Fallback) #}
    <div class="card">
        <h2>Schritte &amp; Status</h2>
        <p class="muted">Die Farbe entspricht der Einfärbung des jeweiligen Schritts in der Grafik.
        Strukturknoten (Start/Ende, Entscheidungen, Parallelgruppen) tragen keine Findings.</p>

        <div class="legend">
            <span class="legend-title">Schritt-Status:</span>
            {% for item in view.legend %}
                <span class="status-badge gs-{{ item.status }}">{{ item.label }}</span>
            {% endfor %}
            <span class="status-badge gs-structure">Struktur</span>
        </div>

        {% if view.withFindings %}
            {% if view.hasProcessFindings %}
                <p class="meta-line">Prozessweite Soll-/Ist-Findings (nicht einzelnen Schritten zuordenbar):
                    {{ view.processDeviations }} Abweichung(en) ·
                    {{ view.processWarnings }} Warnung(en) ·
                    {{ view.processTechnical }} technisch</p>
            {% else %}
                <p class="meta-line muted">Keine prozessweiten Soll-/Ist-Findings festgestellt.</p>
            {% endif %}
        {% endif %}

        <table>
            <thead>
                <tr>
                    <th>Schritt</th>
                    <th>Status</th>
                    <th>Findings (Zusammenfassung)</th>
                </tr>
            </thead>
            <tbody>
                {% for step in view.steps %}
                    <tr>
                        <td>{{ step.name }}{% if is_expert_view() %} <code class="muted">{{ step.key }}</code>{% endif %}</td>
                        <td><span class="status-badge gs-{{ step.status }}">{{ step.statusLabel }}</span></td>
                        <td>{{ step.findingsLabel }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
