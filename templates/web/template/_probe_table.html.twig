{# `probes` = array of probe rows from TemplateAccessView.
   Technical columns are shown only in the expert view; key + description stay
   visible in business view (less prominent). #}
{% if probes is empty %}
    <p class="muted">Keine Access-Probes definiert.</p>
{% else %}
    <table>
        <thead>
            <tr>
                <th>Key</th>
                {% if is_expert_view() %}<th>Source-System</th><th>Typ</th>{% endif %}
                <th>Beschreibung</th>
                {% if is_expert_view() %}<th>max_documents</th><th>page_size</th><th>Referenz (magnet_id)</th>{% endif %}
            </tr>
        </thead>
        <tbody>
            {% for probe in probes %}
                <tr>
                    <td><code>{{ probe.key }}</code></td>
                    {% if is_expert_view() %}
                        <td><code>{{ probe.sourceSystem }}</code></td>
                        <td>{{ probe.type }}</td>
                    {% endif %}
                    <td>{{ probe.description ?? '—' }}</td>
                    {% if is_expert_view() %}
                        <td>{{ probe.maxDocuments ?? '—' }}</td>
                        <td>{{ probe.pageSize ?? '—' }}</td>
                        <td>{{ probe.probeRef ?? '—' }}</td>
                    {% endif %}
                </tr>
            {% endfor %}
        </tbody>
    </table>
    {% if not is_expert_view() %}
        <p class="muted">Technische Probe-Details (Source-System, Typ, magnet_id, page_size, max_documents) in der Technischen Sicht einblendbar.</p>
    {% endif %}
{% endif %}
