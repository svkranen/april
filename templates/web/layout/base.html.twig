<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}APRIL – Amagno Intelligence Tool{% endblock %}</title>
    <style>
        :root {
            --bg: #f4f1ea;
            --paper: #fffdf8;
            --ink: #1f2933;
            --muted: #56646f;
            --line: #e0d8ca;
            --accent: #005f73;
            --accent-deep: #0a2342;
            --shadow-sm: 0 8px 20px rgba(10, 35, 66, 0.07);
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
            color: var(--ink);
            line-height: 1.55;
            background: linear-gradient(180deg, #eef4f3 0%, var(--bg) 18rem, #f8f5ee 100%);
        }
        a { color: var(--accent); }
        .app-header {
            background: linear-gradient(135deg, #073b4c, #0a2342);
            color: #eef9fa;
            box-shadow: var(--shadow-sm);
        }
        .app-header .bar {
            width: min(1180px, calc(100% - 2.5rem));
            margin: 0 auto;
            display: flex; align-items: center; justify-content: space-between;
            gap: 1rem; padding: 1rem 0; flex-wrap: wrap;
        }
        .brand { display: flex; align-items: center; gap: 0.6rem; font-weight: 700; }
        .brand .logo {
            width: 2rem; height: 2rem; border-radius: 0.55rem;
            background: linear-gradient(135deg, #0a9396, #0a2342);
            display: grid; place-items: center; color: #fff; font-weight: 800; font-size: 0.85rem;
        }
        nav.app-nav { display: flex; gap: 1.2rem; flex-wrap: wrap; }
        nav.app-nav a { color: #cfe9ea; text-decoration: none; font-weight: 600; }
        nav.app-nav a.is-active, nav.app-nav a:hover { color: #fff; }
        main.app-main {
            width: min(1180px, calc(100% - 2.5rem));
            margin: 2rem auto 4rem;
        }
        .card {
            background: var(--paper);
            border: 1px solid var(--line);
            border-radius: 1rem;
            padding: 1.5rem;
            box-shadow: var(--shadow-sm);
        }
        h1 { color: var(--accent-deep); margin-top: 0; }
        table { width: 100%; border-collapse: collapse; margin-top: 1rem; }
        th, td { text-align: left; padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--line); vertical-align: top; }
        th { color: var(--muted); font-size: 0.9rem; }
        code { font-family: Consolas, "Liberation Mono", monospace; font-size: 0.9em; }
        .muted { color: var(--muted); }
        h2 { color: var(--accent-deep); font-size: 1.25rem; margin-top: 2rem; }
        .crumbs { margin-bottom: 0.75rem; font-size: 0.9rem; }
        .header-actions { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-top: 1rem; }
        .pill-link {
            display: inline-block; padding: 0.4rem 0.8rem; border-radius: 999px;
            text-decoration: none; font-weight: 600; font-size: 0.9rem;
            border: 1px solid var(--line); background: #fff; color: var(--accent);
        }
        .pill-link.is-disabled {
            color: var(--muted); background: #f3efe8; cursor: not-allowed;
            border-style: dashed; pointer-events: none;
        }
        .meta-line { color: var(--muted); margin: 0.2rem 0; }
        .badge {
            display: inline-block; padding: 0.1rem 0.55rem; border-radius: 999px;
            font-size: 0.78rem; font-weight: 700; border: 1px solid var(--line);
            background: #eef4f3; color: var(--accent-deep);
        }
        .badge.is-muted { color: var(--muted); background: #f3efe8; }
        .summary-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
            gap: 0.8rem; margin-top: 1rem;
        }
        .summary-grid .metric {
            border: 1px solid var(--line); border-radius: 0.8rem; padding: 0.9rem 1rem;
            background: #fcfaf5;
        }
        .summary-grid .metric .n { font-size: 1.5rem; font-weight: 800; color: var(--accent-deep); }
        .summary-grid .metric .l { color: var(--muted); font-size: 0.85rem; }
        .tags span { margin-right: 0.3rem; }
        .compliance {
            border: 1px solid #e3b04b;
            border-left: 5px solid #b5651d;
            background: #fff7e8;
            color: #5b3d12;
            border-radius: 0.8rem;
            padding: 0.9rem 1.1rem;
            margin: 1.25rem 0;
        }
        .compliance strong { color: #7a4d12; }
        .status-badge { display: inline-block; padding: 0.1rem 0.55rem; border-radius: 999px; font-size: 0.78rem; font-weight: 800; }
        .s-automatic { background: rgba(42,138,93,0.18); color: #1f6b46; border: 1px solid rgba(42,138,93,0.4); }
        .s-unsupported { background: rgba(181,101,29,0.18); color: #8a4d12; border: 1px solid rgba(181,101,29,0.4); }
        .s-not_covered { background: rgba(155,34,38,0.16); color: #8a2226; border: 1px solid rgba(155,34,38,0.4); }
        footer.app-footer {
            width: min(1180px, calc(100% - 2.5rem));
            margin: 0 auto; padding: 2rem 0 3rem; color: var(--muted); font-size: 0.9rem;
        }
    </style>
    {% block head '' %}
</head>
<body>
    <header class="app-header">
        <div class="bar">
            <div class="brand"><span class="logo">AI</span> APRIL · Amagno Intelligence Tool</div>
            <nav class="app-nav">
                <a href="{{ path('app_templates_index') }}" class="{{ active_nav|default('') == 'templates' ? 'is-active' : '' }}">Templates</a>
            </nav>
        </div>
    </header>

    <main class="app-main">
        {% block body %}{% endblock %}
    </main>

    <footer class="app-footer">
        APRIL · Prozessmonitoring &amp; Audit für dokumentenbasierte Prozesse
    </footer>
</body>
</html>
