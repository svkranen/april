{% extends 'layout/base.html.twig' %}

{% block title %}Template-Entwurf · {{ view.documentUuid }} · APRIL{% endblock %}

{% block head %}
    <style>
        .yaml-source {
            background: #0a2342; color: #eef9fa; border-radius: 0.8rem;
            padding: 1rem 1.1rem; overflow-x: auto; font-size: 0.85rem; line-height: 1.5;
            font-family: Consolas, "Liberation Mono", monospace; margin: 0.6rem 0 0;
        }
        .mermaid-preview {
            margin-top: 0.6rem; padding: 1rem; border: 1px solid var(--line);
            border-radius: 0.8rem; background: #fff; overflow-x: auto; min-height: 3rem;
        }
        .mermaid-preview svg { max-width: 100%; height: auto; }
        .draft-form fieldset { border: 1px solid var(--line); border-radius: 0.8rem; padding: 0.8rem 1rem; margin: 0.8rem 0 0; }
        .draft-form legend { font-weight: 700; padding: 0 0.4rem; }
        .draft-form label { display: block; margin: 0.35rem 0; }
        .draft-form select, .draft-form input[type="text"] { padding: 0.35rem 0.5rem; min-width: 18rem; max-width: 100%; }
    </style>
    {% if view.preview and view.preview.found %}
        {# Mermaid + Copy-Button lokal via AssetMapper/importmap (kein CDN). #}
        {{ importmap(['template-graph', 'template-draft']) }}
    {% endif %}
{% endblock %}

{% block body %}
    <div class="card">
        <p class="crumbs">
            {% if view.documentUuid %}
                <a href="{{ path('app_intelligence_documents_show', view.documentVersion ? { documentUuid: view.documentUuid, documentVersion: view.documentVersion } : { documentUuid: view.documentUuid }) }}">← Zurück zum {{ 'glossary.item'|trans({}, 'glossary') }}</a>
                &nbsp;·&nbsp;
            {% endif %}
            <a href="{{ path('app_intelligence_documents_index') }}">Item-Suche</a>
        </p>
        <h1>Template-Entwurf aus einem {{ 'glossary.item'|trans({}, 'glossary') }} erstellen</h1>
        {% if view.documentUuid %}
            <p class="meta-line">Item UUID: <code>{{ view.documentUuid }}</code></p>
        {% endif %}
        {% if view.documentVersion %}
            <p class="meta-line">Item-Version: <strong>{{ view.documentVersion }}</strong></p>
        {% endif %}
        <p class="muted">Read-only Vorschau: Der Entwurf wird aus der Event-Timeline dieses einen Items
        abgeleitet (wie <code>intelligence:template:suggest-from-document</code>). Es wird nichts auf dem
        Server gespeichert und kein bestehendes Template veraendert – das YAML kann kopiert oder als
        Datei heruntergeladen werden.</p>
    </div>

    {% if view.inputError %}
        <div class="card">
            <h2>Eingabe unvollstaendig</h2>
            <p>{{ view.inputError }}</p>
        </div>
    {% else %}
        <div class="card">
            <h2>Entwurf konfigurieren</h2>
            <form class="draft-form" method="get" action="{{ path('app_intelligence_template_draft') }}">
                <input type="hidden" name="documentUuid" value="{{ view.documentUuid }}">
                {% if view.documentVersion %}
                    <input type="hidden" name="documentVersion" value="{{ view.documentVersion }}">
                {% endif %}

                <fieldset>
                    <legend>Template-Typ</legend>
                    <label>
                        <input type="radio" name="scope" value="process" {{ view.selectedScope == 'process' ? 'checked' : '' }}>
                        Prozess-Template – ein einzelner Prozess (Process Key) dieses Items
                    </label>
                    <label>
                        <input type="radio" name="scope" value="journey" {{ view.selectedScope == 'journey' ? 'checked' : '' }}>
                        Journey-Template – prozessuebergreifend ueber alle beobachteten Prozesse
                    </label>
                </fieldset>

                <fieldset>
                    <legend>Bei Prozess-Template: Process Key</legend>
                    {% if view.hasObservedProcessKeys %}
                        <label>
                            <select name="processKey">
                                {% for processKey, knownTemplate in view.knownTemplatesByProcessKey %}
                                    <option value="{{ processKey }}" {{ view.selectedTemplateKey == processKey ? 'selected' : '' }}>
                                        {{ processKey }}{{ knownTemplate ? ' (Template bereits vorhanden)' : '' }}
                                    </option>
                                {% endfor %}
                            </select>
                        </label>
                        <p class="muted">Der Process Key ist zugleich der Key des Entwurfs. Nur Events dieses Prozesses fliessen ein.</p>
                    {% else %}
                        <p class="muted">Fuer dieses Item sind keine Process Keys bekannt.</p>
                    {% endif %}
                </fieldset>

                <fieldset>
                    <legend>Bei Journey-Template: Key fuer den Entwurf</legend>
                    <label>
                        <input type="text" name="journeyKey" value="{{ view.selectedScope == 'journey' ? (view.selectedTemplateKey ?? view.defaultJourneyKey) : view.defaultJourneyKey }}" pattern="[A-Za-z0-9._:-]+">
                    </label>
                    <p class="muted">Alle beobachteten Prozesse des Items werden als Journey-Schritte vorgeschlagen.</p>
                </fieldset>

                <p><button type="submit" class="pill-link">Entwurf erzeugen</button></p>
            </form>
        </div>
    {% endif %}

    {% if view.preview %}
        {% set preview = view.preview %}
        {% if preview.errorMessage %}
            <div class="card">
                <h2>Entwurf konnte nicht erzeugt werden</h2>
                <p>{{ preview.errorMessage }}</p>
            </div>
        {% elseif not preview.found %}
            <div class="card">
                <h2>Keine Events gefunden</h2>
                <p class="muted">Fuer {{ 'glossary.item'|trans({}, 'glossary') }} <code>{{ preview.documentUuid }}</code>
                {% if preview.documentVersion %} in Version {{ preview.documentVersion }}{% endif %}
                und Key <code>{{ preview.templateKey }}</code> ({{ preview.scope }}) liegen keine auswertbaren
                Events vor. Bitte Process Key bzw. Version pruefen.</p>
            </div>
        {% else %}
            <div class="card">
                <h2>Entwurf: <code>{{ preview.templateKey }}</code></h2>
                <p class="meta-line">Typ: <strong>{{ preview.scope == 'journey' ? 'Journey-Template' : 'Prozess-Template' }}</strong></p>
                <p class="meta-line">{{ preview.stepCount }} Schritt(e) · {{ preview.transitionCount }} Uebergaenge</p>
                <p class="meta-line">
                    {% if preview.isValid %}
                        <span class="badge">Template-Factory: gueltig</span>
                    {% else %}
                        <span class="badge is-muted">Template-Factory: Validierungsfehler</span>
                    {% endif %}
                </p>
                <div class="header-actions">
                    <a class="pill-link" href="{{ path('app_intelligence_template_draft_download', {
                        documentUuid: preview.documentUuid,
                        documentVersion: preview.documentVersion,
                        scope: preview.scope,
                        templateKey: preview.templateKey
                    }|filter(v => v is not null)) }}">Als Datei herunterladen ({{ preview.downloadFilename }})</a>
                    {# Progressive enhancement: only useful with JavaScript, revealed by template-draft.js. #}
                    <button type="button" class="pill-link" data-template-draft-copy hidden>YAML kopieren</button>
                </div>
            </div>

            {% if not preview.isValid %}
                <div class="card">
                    <h2>Validierungsfehler der Template-Factory</h2>
                    <p class="muted">Der Entwurf laesst sich nicht mit der regulaeren Template-Factory laden –
                    so wuerde er auch im Katalog fehlschlagen. Bitte vor Verwendung korrigieren.</p>
                    <p><code>{{ preview.validationError }}</code></p>
                </div>
            {% endif %}

            {% if preview.warnings is not empty %}
                <div class="card">
                    <h2>Warnungen des Suggestion-Services</h2>
                    <table>
                        <thead>
                            <tr><th>Typ</th><th>Meldung</th></tr>
                        </thead>
                        <tbody>
                            {% for warning in preview.warnings %}
                                <tr>
                                    <td><span class="badge is-muted">{{ warning.type }}</span></td>
                                    <td>{{ warning.message }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}

            {% if preview.suggestions is not empty %}
                <div class="card">
                    <h2>Hinweise des Suggestion-Services</h2>
                    <table>
                        <thead>
                            <tr><th>Typ</th><th>Meldung</th></tr>
                        </thead>
                        <tbody>
                            {% for note in preview.suggestions %}
                                <tr>
                                    <td><span class="badge is-muted">{{ note.type }}</span></td>
                                    <td>{{ note.message }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}

            {% if preview.mermaidCode %}
                <div class="card">
                    <h2>Grafische Vorschau</h2>
                    <p class="muted">Gerendert aus dem Entwurf – mit demselben Graph-Builder wie die Prozessgrafik
                    bestehender Templates.</p>
                    <div class="mermaid-preview" data-mermaid-graph-target="preview">
                        <noscript>Die grafische Vorschau benoetigt JavaScript. Der Mermaid-Quelltext ist unten als Fallback enthalten.</noscript>
                    </div>
                    <details>
                        <summary>Mermaid-Quelltext anzeigen/ausblenden</summary>
                        {# Read as plain text by template-graph.js; HTML-escaped, never injected as markup. #}
                        <pre class="yaml-source" data-mermaid-graph-source>{{ preview.mermaidCode }}</pre>
                    </details>
                </div>
            {% endif %}

            <div class="card">
                <h2>YAML-Entwurf</h2>
                <p class="muted">Identisch zur CLI-Ausgabe von <code>intelligence:template:suggest-from-document</code>.
                Zum Aktivieren als Datei unter <code>config/april/process-templates/</code> ablegen.</p>
                <pre class="yaml-source" data-template-draft-yaml>{{ preview.yaml }}</pre>
            </div>
        {% endif %}
    {% endif %}
{% endblock %}
