{% extends 'layout/base.html.twig' %}

{% block title %}{{ 'glossary.items'|trans({}, 'glossary') }} · Event Explorer · APRIL{% endblock %}

{% block body %}
    <div class="card">
        <p class="crumbs"><a href="{{ path('app_templates_index') }}">Template-Liste</a></p>
        <h1>{{ 'glossary.items'|trans({}, 'glossary') }}</h1>
        <p class="muted">Hier koennen itembezogene Events auch ohne Prozess-Template nachvollzogen werden.</p>

        <form class="login-form" method="get" action="{{ path('app_intelligence_documents_index') }}">
            <label for="documentUuid">Item UUID</label>
            <input id="documentUuid" name="documentUuid" value="{{ view.query ?? '' }}" autocomplete="off" placeholder="z. B. 8f3c..." required>
            {% if view.error %}
                <div class="login-error">{{ view.error }}</div>
            {% endif %}
            <button type="submit">{{ 'glossary.item'|trans({}, 'glossary') }} anzeigen</button>
        </form>

        <p class="muted">Der MVP sucht direkt nach einer bekannten Item UUID. Eine globale Item-Liste folgt spaeter.</p>
        <p><a class="pill-link" href="{{ path('app_intelligence_process_keys_index') }}">Verwendete Process Keys</a></p>
    </div>
{% endblock %}
