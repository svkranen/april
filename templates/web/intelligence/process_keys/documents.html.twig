{% extends 'layout/base.html.twig' %}

{% block title %}{{ view.processKey }} · {{ 'glossary.items'|trans({}, 'glossary') }} · Event Explorer · APRIL{% endblock %}

{% block body %}
    <div class="card">
        <p class="crumbs">
            <a href="{{ path('app_intelligence_process_keys_index') }}">← Zurück zu verwendeten Process Keys</a>
            &nbsp;·&nbsp;
            <a href="{{ path('app_intelligence_documents_index') }}">Item-Suche</a>
        </p>
        <h1>{{ 'glossary.items'|trans({}, 'glossary') }} für <code>{{ view.processKey }}</code></h1>
        <p class="meta-line">processKey: <code>{{ view.processKey }}</code></p>
        <p class="meta-line">
            {% if view.knownTemplate %}
                <span class="badge">Template bekannt</span>
            {% else %}
                <span class="badge is-muted">kein Template bekannt</span>
            {% endif %}
        </p>
        <p class="muted">Diese Liste basiert nur auf gespeicherten Events. Es findet keine Template-, Soll-/Ist- oder Visibility-Prüfung statt.</p>
    </div>

    <div class="card">
        <h2>Betroffene {{ 'glossary.items'|trans({}, 'glossary') }}</h2>

        {% if not view.hasRows %}
            <p class="muted">Für diesen Process Key sind APRIL aktuell keine Items bekannt.</p>
        {% else %}
            <table>
                <thead>
                    <tr>
                        <th>Item UUID</th>
                        <th>Externe ID</th>
                        <th>Version</th>
                        <th>Events</th>
                        <th>Erstes Event</th>
                        <th>Letztes Event</th>
                        <th>Aktionen</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in view.rows %}
                        {% set journeyParams = { documentUuid: row.documentUuid } %}
                        {% if row.documentVersion is not null %}
                            {% set journeyParams = journeyParams|merge({ documentVersion: row.documentVersion }) %}
                        {% endif %}
                        <tr>
                            <td><code>{{ row.documentUuid }}</code></td>
                            <td>{{ row.documentExternalId ?? '—' }}</td>
                            <td>{{ row.documentVersion is not null ? row.documentVersion : '—' }}</td>
                            <td>{{ row.eventCount }}</td>
                            <td>{{ row.firstOccurredAt ? row.firstOccurredAt|date('Y-m-d H:i') : '—' }}</td>
                            <td>{{ row.lastOccurredAt ? row.lastOccurredAt|date('Y-m-d H:i') : '—' }}</td>
                            <td>
                                <a class="pill-link" href="{{ path('app_intelligence_documents_show', journeyParams) }}">Journey</a>
                                {% if not view.knownTemplate %}
                                    <a class="pill-link" href="{{ path('app_intelligence_template_draft', journeyParams|merge({ scope: 'process', templateKey: view.processKey })) }}">Template-Entwurf</a>
                                {% endif %}
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
